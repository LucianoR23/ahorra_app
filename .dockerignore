# Dependencies & build artifacts — rebuilt inside the image
node_modules
.pnp
.pnp.*
.yarn
.next
out
build
coverage

# VCS & editor
.git
.gitignore
.gitattributes
.vscode
.idea
.claude

# Local env — secrets must be passed at build/run time, not baked in
.env
.env.local
.env.*.local

# Logs & caches
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo

# OS / misc
.DS_Store
Thumbs.db
*.pem

# Vercel
.vercel

# Docker-related (avoid recursive copy)
Dockerfile
.dockerignore

# Docs & non-runtime files
README.md
DEPLOY.md
API_REFERENCE.md
plan-proyecto-gastos.md
*.md
!public/**/*.md

# Generated SW (Serwist rebuilds it)
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map
