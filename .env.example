# ── App ───────────────────────────────────────────────────────────────────────
# URL pública canónica de la app (sin trailing slash). La usa Next para
# resolver las imágenes de Open Graph / Twitter en previews al compartir.
# Ej: https://ahorra.app  o  https://ahorra.lemydev.com
NEXT_PUBLIC_APP_URL=

# ── API ───────────────────────────────────────────────────────────────────────
# URL base del backend (sin trailing slash).
NEXT_PUBLIC_API_URL=

# ── Versión de la app ─────────────────────────────────────────────────────────
# Se adjunta como `app_version` en la metadata de los reportes de soporte
# (sirve para saber qué build tenía el usuario al reportar un bug). Se inlinea
# en build-time. En prod (Coolify) pasala como build arg = `0.1.0+${SOURCE_COMMIT}`
# para pinpointear el commit. En dev poné `dev` o dejala vacía (manda undefined).
NEXT_PUBLIC_APP_VERSION=dev

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Clave pública VAPID — misma que el backend usa como VAPID_PUBLIC_KEY.
# Generá el par una sola vez con: go run ./cmd/vapidgen (repo del backend).
# La clave PRIVADA queda SOLO en el backend. Nunca la pongas acá.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
